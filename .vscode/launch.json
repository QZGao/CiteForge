{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Cite Forge on Firefox",
			"type": "firefox",
			"request": "launch",
			"reAttach": true,
			"url": "https://en.wikipedia.org/wiki/Varsapura",
			"webRoot": "${workspaceFolder}",
			"addonPath": "${workspaceFolder}/.debug",
			"preLaunchTask": "watch-debug-extension",
			"reloadOnChange": {
				"watch": [
					"${workspaceFolder}/.debug/bundled.js",
					"${workspaceFolder}/.debug/inject.js",
					"${workspaceFolder}/.debug/manifest.json"
				],
				"debounce": 200
			},
			"skipFiles": [
				"**/load.php*",
				"**/ext.*.js"
			]
		},
		{
			"name": "Debug Cite Forge on Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "https://en.wikipedia.org/wiki/Varsapura",
			"webRoot": "${workspaceFolder}",
			"preLaunchTask": "prepare-debug-chrome",
			"runtimeExecutable": "${workspaceFolder}/.debug/chrome/chrome-win64/chrome.exe",
			"runtimeArgs": [
				"--user-data-dir=${workspaceFolder}/.debug/chrome-profile",
				"--disable-extensions-except=${workspaceFolder}/.debug",
				"--load-extension=${workspaceFolder}/.debug"
			],
			"skipFiles": [
				"**/load.php*",
				"**/ext.*.js"
			]
		}
	]
}