{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "install-debug-chrome-for-testing",
			"type": "shell",
			"command": "node scripts/install_chrome_for_testing.mjs"
		},
		{
			"label": "watch-debug-extension",
			"type": "shell",
			"command": "npm run watch:debug",
			"isBackground": true,
			"problemMatcher": {
				"owner": "citeforge-watch",
				"fileLocation": [
					"relative",
					"${workspaceFolder}"
				],
				"pattern": [
					{
						"regexp": "^\\s*(.+):(\\d+):(\\d+):\\s+(ERROR|WARN|WARNING):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[Cite Forge build\\] Watching for changes\\.\\.\\.",
					"endsPattern": "\\[Cite Forge build\\] Watching for changes\\.\\.\\."
				}
			}
		},
		{
			"label": "prepare-debug-chrome",
			"dependsOrder": "sequence",
			"dependsOn": [
				"install-debug-chrome-for-testing",
				"watch-debug-extension"
			]
		}
	]
}
